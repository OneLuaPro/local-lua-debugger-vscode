{
    "compilerOptions":
    {
        "target": "es6",
        "strict": true,
        "noLib": true,
        "sourceMap": true,
        "rootDir": ".",
        "noUncheckedIndexedAccess": true,
	"moduleResolution": "node",
	"baseUrl": ".",
	"paths": {
            "*": ["node_modules/*"]
	},
	"types": []
    },
    "include": [
        "./**/*.ts",
	"../node_modules/lua-types/5.5.d.ts",
        "../node_modules/typescript-to-lua/language-extensions.d.ts"
    ],
    "tstl":
    {
        "luaTarget": "5.1",
        "noImplicitSelf": true,
        "noHeader": true,
        "luaBundle": "lldebugger.lua",
        "luaBundleEntry": "lldebugger.ts",
        "luaLibImport": "none"
    }
}
